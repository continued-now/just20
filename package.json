{
  "name": "just20",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:device": "bash scripts/android-device.sh",
    "android:webcam": "bash scripts/android-webcam.sh",
    "ios": "expo run:ios",
    "landing": "python3 -m http.server 8082 --directory landing",
    "landing2": "python3 -m http.server 8083 --directory landing2",
    "badges:mockups": "python3 -m http.server 8084 --directory badge-mockups",
    "logos:mockups": "python3 -m http.server 8085 --directory logo-mockups",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint app components hooks lib --no-cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --no-warnings --test tests/*.test.mjs",
    "check:native-config": "node scripts/check-native-config.js",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run check:native-config && npx expo-doctor"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "^7.3.6",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^1.6.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "tailwindcss": "^4.2.4",
    "vision-camera-resize-plugin": "^3.2.0"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fast-tflite",
          "vision-camera-resize-plugin"
        ]
      }
    }
  }
}
